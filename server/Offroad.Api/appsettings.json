{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=offroad;Username=offroad;Password=offroad"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": { "restrictedToMinimumLevel": "Error" }
      },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "Routing": {
    "ParksGeoJsonPath": "../../routing/graphhopper/data/restricted_areas/cz_national_parks.geojson.json",
    "FilteredNatureGeoJsonPath": "../../routing/graphhopper/data/offroad_areas/filtered-nature.geojson"
  }
}