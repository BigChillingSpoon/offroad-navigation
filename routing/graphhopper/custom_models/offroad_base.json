{
  "distance_influence": 70, 
  "priority": [
    { "if": "car_access == false && road_class != TRACK", "multiply_by": "0" }
  ],
  "speed": [
    { "if": "track_type == GRADE4 || track_type == GRADE5", "limit_to": 15 },
